# Convex API base URL (e.g., https://happy-amber-123.convex.cloud)
CONVEX_URL=https://your-convex-deployment.convex.cloud

# Clerk authentication (required in production; dev falls back to a test key)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Admin key for Convex HTTP actions (store securely)
CONVEX_ADMIN_KEY=convex_admin_key_placeholder

# Billing provider selector (values: paypal, polar)
BILLING_PROVIDER=paypal

# Polar configuration (required when BILLING_PROVIDER=polar)
POLAR_ACCESS_TOKEN=polar_access_token_placeholder
POLAR_ORGANIZATION_ID=polar_org_id_placeholder
# POLAR_ENVIRONMENT=sandbox
POLAR_PLAN_ID=polar_plan_id_placeholder
# POLAR_PLAN_ID_STARTER=another_plan_id_if_you_segment
POLAR_CHECKOUT_SUCCESS_URL=https://your-domain.com/billing/success
POLAR_CHECKOUT_CANCEL_URL=https://your-domain.com/billing/cancel
POLAR_CUSTOMER_PORTAL_URL=https://polar.sh/your-org-slug/portal
POLAR_WEBHOOK_SECRET=polar_webhook_secret_placeholder

# Legacy PayPal configuration (only when BILLING_PROVIDER=paypal)
PAYPAL_CLIENT_ID=paypal_client_id_placeholder
PAYPAL_CLIENT_SECRET=paypal_client_secret_placeholder
PAYPAL_PLAN_ID=paypal_plan_id_placeholder
PAYPAL_SUCCESS_URL=https://your-domain.com/billing/success
PAYPAL_CANCEL_URL=https://your-domain.com/billing/cancel
PAYPAL_PORTAL_URL=https://www.sandbox.paypal.com/myaccount/autopay/
# PAYPAL_PLAN_ID_STARTER=another_plan_id_if_you_segment
# PAYPAL_ENVIRONMENT=live

# Optional: trial length in days for premium upgrades
PREMIUM_TRIAL_DAYS=14

# OpenAI configuration
OPENAI_API_KEY=openai_api_key_placeholder
# OPENAI_PIPELINE_MODEL=gpt-4.1-mini
# OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
# OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# OPENAI_TRANSCRIPTIONS_URL=https://api.openai.com/v1/audio/transcriptions
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# OPENAI_REALTIME_SESSIONS_URL=https://api.openai.com/v1/realtime/sessions
# OPENAI_REALTIME_WS_URL=wss://api.openai.com/v1/realtime
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# OpenAI feature flags
# OPENAI_USE_RESPONSES_API=true
# OPENAI_USE_REALTIME_TRANSIT=true
# OPENAI_USE_REALTIME_TTS=true

# Legacy local persistence fallback (only for development without Convex)
# PROVISIONING_DATA_PATH=.data/provisioning.json
